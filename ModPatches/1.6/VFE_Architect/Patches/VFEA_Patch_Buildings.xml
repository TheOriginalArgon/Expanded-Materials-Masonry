<Patch>

    <Operation Class="PatchOperationReplace">
        <xpath>/Defs/TerrainDef [
            defName="VFEArch_ConcreteFoundation"
            ]/costList/Steel</xpath>
        <value>
            <Steel>1</Steel>
            <EM_CementMix>4</EM_CementMix>
        </value>
    </Operation>

    <Operation Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
        <xpath>/Defs/TerrainDef [
            defName="VFEArch_PlayerBrokenAsphalt" or
            defName="VFEArch_Asphalt"
            ]/costList/Steel</xpath>
        <newMaterial>EM_CementMix</newMaterial>
        <percentage>100</percentage>
        <round>false</round>
        <minimum>0</minimum>
    </Operation>

</Patch>