<Patch>

    <Operation Class="PatchOperationAddModExtension">
        <xpath>/Defs/ThingDef [@ParentName="ChunkRockBase" and not(defName="ChunkVacstone")]</xpath>
        <value>
            <li Class="ArgonicCore.ModExtensions.ThingDefExtension_DiggableResource">
                <minimumPortion>1</minimumPortion>
                <difficultyFactor>2.3</difficultyFactor>
                <priorityInList>10</priorityInList>
                <resourceTags>
                    <li>Stone</li>
                </resourceTags>
            </li>
        </value>
    </Operation>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Odyssey</li>
        </mods>
        <match Class="PatchOperationAddModExtension">
            <xpath>/Defs/ThingDef [defName="ChunkVacstone"]</xpath>
            <value>
                <li Class="ArgonicCore.ModExtensions.ThingDefExtension_DiggableResource">
                    <minimumPortion>1</minimumPortion>
                    <difficultyFactor>2.3</difficultyFactor>
                    <priorityInList>11</priorityInList>
                    <resourceTags>
                        <li>SpaceStone</li>
                    </resourceTags>
                </li>
            </value>
        </match>
    </Operation>

</Patch>