<Patch>

    <!-- ================================ VANILLA BUILDINGS PATCH ================================ -->

    <!-- Replace steel with concrete in immovable buildings. -->
     <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Attempt to replace steel with concrete in immovable buildings:</label>
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/ThingDef [thingClass="Building" and not(minifiedThing) and costList/Steel > 80]/costList/Steel</xpath>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [thingClass="Building" and not(minifiedThing) and costList/Steel > 80]/costList/Steel</xpath>
                    <newMaterial>EM_Soil</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>
        </operations>
     </Operation>

</Patch>