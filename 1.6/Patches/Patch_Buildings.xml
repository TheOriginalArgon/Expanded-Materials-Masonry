                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="EM_FlagstoneBasalt"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneBasalt>4</EM_CobblestoneBasalt>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="EM_FlagstoneShale"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneShale>4</EM_CobblestoneShale>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="EM_FlagstoneSiltstone"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneSiltstone>4</EM_CobblestoneSiltstone>
                    </costList>
                </value>
            </li>

            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Furniture Expanded - Architect</li>
                </mods>
                <match Class="PatchOperationSequence">
                    <operations>
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorSandstone"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneSandstone>4</EM_CobblestoneSandstone>
                                </costList>
                            </value>
                        </li>
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorGranite"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneGranite>4</EM_CobblestoneGranite>
                                </costList>
                            </value>
                        </li>
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorLimestone"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneLimestone>4</EM_CobblestoneLimestone>
                                </costList>
                            </value>
                        </li>
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorSlate"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneSlate>4</EM_CobblestoneSlate>
                                </costList>
                            </value>
                        </li>
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorMarble"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneMarble>4</EM_CobblestoneMarble>
                                </costList>
                            </value>
                        </li>

                        <!-- Added -->
                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="EM_VFEArch_CobblestoneFloorSchist"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneSchist>4</EM_CobblestoneSchist>
