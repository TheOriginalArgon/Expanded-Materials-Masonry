                    </costList>
                </value>
            </li>

            <!-- Modded -->
            <li Class="PatchOperationReplace" MayRequire="vanillaexpanded.vfearchitect">
                <xpath>/Defs/TerrainDef [defName="VFEArch_CobblestoneFloorSandstone"]/costList</xpath>
