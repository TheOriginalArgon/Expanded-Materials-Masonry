    <!-- ================================ CONCRETE PATCHES ================================ -->

    <!-- Replace steel with concrete -->
    <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Enable manual concrete patches:</label>
        <operations>

            <!-- Vanilla -->
            <li Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                <xpath>/Defs/ThingDef [
                    defName="GeothermalGenerator" or
                    defName="Turret_Autocannon" or
                    defName="Turret_Sniper" or
                    defName="Turret_RocketswarmLauncher"
                    ]/costList/Steel</xpath>
                <newMaterial>EM_CementMix</newMaterial>
                <splitMode>small</splitMode>
            </li>

            <!-- Concrete in paved tiles and VFE Architect asphalt -->
            <li Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                <xpath>/Defs/TerrainDef [
                    defName="Concrete" or
                    defName="PavedTile" or
                    defName="VFEArch_PlayerBrokenAsphalt" or
                    defName="VFEArch_Asphalt"
                    ]/costList/Steel</xpath>
                <newMaterial>EM_CementMix</newMaterial>
                <splitMode>replace</splitMode>
                <minimum>0</minimum>
            </li>

            <!-- Biotech -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Biotech</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="MechGestator" or
                        defName="LargeMechGestator" or
                        defName="BasicRecharger" or
                        defName="StandardRecharger"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Factions Expanded - Pirates -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Factions Expanded - Pirates</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="VFEP_WarcasketFoundry"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Furniture Expanded -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Furniture Expanded</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="Light_Streetlamp"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Furniture Expanded - Power -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Furniture Expanded - Power</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="VFE_AdvancedWatermillGenerator" or
                        defName="VPE_AdvancedGeothermalGenerator" or
                        defName="VPE_NuclearGenerator" or
                        defName="VFE_TidalGenerator"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Furniture Expanded - Security -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Furniture Expanded - Security</li>
                </mods>
                <match Class="PatchOperationSequence">
                    <operations>
                        <li Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                            <xpath>/Defs/ThingDef [
                                defName="VFES_Turret_AutocannonDouble" or
                                defName="VFES_Turret_Minigun" or
                                defName="VFES_Turret_AntiAir" or
                                defName="VFES_LargeRepulsor"
                                ]/costList/Steel</xpath>
                            <newMaterial>EM_CementMix</newMaterial>
                            <splitMode>small</splitMode>
                        </li>
                        <li Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                            <xpath>/Defs/ThingDef [
                                defName="VFES_Turret_Concealed" or
                                defName="VFES_ConcealedBarrier"
                                ]/costList/Steel</xpath>
                            <newMaterial>EM_CementMix</newMaterial>
                            <splitMode>big</splitMode>
                        </li>
                    </operations>
                </match>
            </li>

            <!-- Vanilla Factions Expanded - Deserters -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Factions Expanded - Deserters</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="VFED_Turret_Kontarion" or
                        defName="VFED_Turret_Palintone" or
                        defName="VFED_Turret_Onager"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Genetics Expanded -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Genetics Expanded</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="GR_GenePod"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Chemfuel Expanded -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Chemfuel Expanded</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="PS_DeepchemRefinery" or
                        defName="VCHE_DeepchemPumpjack"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

            <!-- Vanilla Chemfuel Expanded -->
            <li Class="PatchOperationFindMod">
                <mods>
                    <li>Vanilla Helixien Gas Expanded</li>
                </mods>
                <match Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
                    <xpath>/Defs/ThingDef [
                        defName="VHGE_HelixienPump"
                        ]/costList/Steel</xpath>
                    <newMaterial>EM_CementMix</newMaterial>
                    <splitMode>small</splitMode>
                </match>
            </li>

        </operations>
    </Operation>

    <!-- SANDBAGS REQUIRE SAND -->
    <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Sandbags require sand:</label>
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/ThingDef [defName="Sandbags"]/costList</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/ThingDef [defName="Sandbags"]</xpath>
                    <value>
                        <costList />
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>/Defs/ThingDef [defName="Sandbags"]/costList</xpath>
                <value>
                    <EM_Sand>10</EM_Sand>
                </value>
            </li>
        </operations>
    </Operation>

    <!-- Flagstone requires cobblestone -->
    <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Flagstone requires cobblestone:</label>
