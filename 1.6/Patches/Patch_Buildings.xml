                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="EM_VFEArch_CobblestoneFloorSiltstone"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneSiltstone>4</EM_CobblestoneSiltstone>
                                </costList>
                            </value>
                        </li>
                    </operations>
                </match>
            </li>
        </operations>
    </Operation>

</Patch>