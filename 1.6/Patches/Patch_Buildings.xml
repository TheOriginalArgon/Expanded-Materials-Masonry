<Patch>

    <!-- ================================ CONCRETE PATCHES ================================ -->

    <!-- Vanilla Buildings -->
    <Operation Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
        <xpath>/Defs/ThingDef [
            defName="GeothermalGenerator" or
            defName="Turret_Autocannon" or
            defName="Turret_Sniper" or
            defName="Turret_RocketswarmLauncher"
            ]/costList/Steel</xpath>
        <newMaterial>EM_CementMix</newMaterial>
        <percentage>25</percentage>
        <extraCostFactor>2</extraCostFactor>
    </Operation>

    <!-- Concrete in paved tiles and concrete (well, duh) -->
    <!-- There's one from ReBuild: Doors and Corners because it's easier to put it here than to do the mess I have to make to check for it elsewhere. -->
    <Operation Class="ArgonicCore.PatchOperations.PatchOperationDistributeCost">
        <xpath>/Defs/TerrainDef [
            defName="Concrete" or
            defName="PavedTile" or
            defName="RB_PavedTile_Transhumanist"
            ]/costList/Steel</xpath>
        <newMaterial>EM_CementMix</newMaterial>
        <percentage>100</percentage>
        <round>false</round>
        <minimum>0</minimum>
    </Operation>

    <!-- SANDBAGS REQUIRE SAND -->
    <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Sandbags require sand:</label>
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>/Defs/ThingDef [defName="Sandbags"]/costList</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>/Defs/ThingDef [defName="Sandbags"]</xpath>
                    <value>
                        <costList />
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>/Defs/ThingDef [defName="Sandbags"]/costList</xpath>
                <value>
                    <EM_Sand>10</EM_Sand>
                </value>
            </li>
        </operations>
    </Operation>

    <!-- Flagstone requires cobblestone -->
    <Operation Class="VEF.PatchOperationToggableSequence">
        <enabled>true</enabled>
        <label>Flagstone requires cobblestone:</label>
        <operations>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="FlagstoneSandstone"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneSandstone>4</EM_CobblestoneSandstone>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="FlagstoneGranite"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneGranite>4</EM_CobblestoneGranite>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="FlagstoneLimestone"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneLimestone>4</EM_CobblestoneLimestone>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="FlagstoneSlate"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneSlate>4</EM_CobblestoneSlate>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="FlagstoneMarble"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneMarble>4</EM_CobblestoneMarble>
                    </costList>
                </value>
            </li>

            <!-- Added -->
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="EM_FlagstoneSchist"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneSchist>4</EM_CobblestoneSchist>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/TerrainDef [defName="EM_FlagstoneBasalt"]/costList</xpath>
                <value>
                    <costList>
                        <EM_CobblestoneBasalt>4</EM_CobblestoneBasalt>
                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace">
