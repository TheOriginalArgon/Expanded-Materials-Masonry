                    </costList>
                </value>
            </li>
            <li Class="PatchOperationReplace" MayRequire="vanillaexpanded.vfearchitect">
                <xpath>/Defs/TerrainDef [defName="EM_VFEArch_CobblestoneFloorShale"]/costList</xpath>
                <value>
