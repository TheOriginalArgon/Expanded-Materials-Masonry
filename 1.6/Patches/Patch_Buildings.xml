                        <li Class="PatchOperationReplace">
                            <xpath>/Defs/TerrainDef [defName="EM_VFEArch_CobblestoneFloorShale"]/costList</xpath>
                            <value>
                                <costList>
                                    <EM_CobblestoneShale>4</EM_CobblestoneShale>
                                </costList>
                            </value>
