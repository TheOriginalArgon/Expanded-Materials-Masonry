<Defs>

    <PipeSystem.ProcessDef>
        <defName>EM_CementRecipe_Limestone</defName>
        <label>Make cement (limestone)</label>
        <description>Turns 1 limestone chunk and 20 sand into 30 cement.</description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Make 30 cement from 1 limestone chunk and 20 sand</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <ingredients>
            <li>
                <thing>ChunkLimestone</thing>
                <countNeeded>1</countNeeded>
            </li>
            <li>
                <thing>EM_Sand</thing>
                <countNeeded>20</countNeeded>
            </li>
        </ingredients>
        <ticks>50000</ticks>
        <results>
            <li>
                <thing>EM_CementMix</thing>
                <count>30</count>
            </li>
        </results>
        <researchPrerequisites>
            <li>EM_Concrete</li>
        </researchPrerequisites>
    </PipeSystem.ProcessDef>

