<Defs>

    <PipeSystem.ProcessDef>
        <defName>EM_SoilToAdobeBricks</defName>
        <label>Make adobe bricks</label>
        <description>Turns 20 soil into 10 adobe bricks.</description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Make 10 adobe bricks from 20 soil</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <ingredients>
            <li>
                <thing>EM_Soil</thing>
                <countNeeded>20</countNeeded>
            </li>
        </ingredients>
        <ticks>50000</ticks>
        <results>
            <li>
                <thing>EM_AdobeBricks</thing>
                <count>10</count>
            </li>
        </results>
        <isRainDependingProcess>true</isRainDependingProcess>
        <messageIfRainingWarning>EM_RainIsRuiningBricks</messageIfRainingWarning>
        <messageIfRaining>EM_RainRuinedBricks</messageIfRaining>
        <minLight>0.4</minLight>
        <maxLight>1</maxLight>
        <researchPrerequisites>
            <li>EM_BasicMasonry</li>
        </researchPrerequisites>
    </PipeSystem.ProcessDef>

    <PipeSystem.ProcessDef>
        <defName>EM_ClayToBricks</defName>
        <label>Make clay bricks</label>
        <description>Turns 100 clay into 50 clay bricks.</description>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <labelOverride>Make 50 clay bricks from 100 clay</labelOverride>
        <priorityInBillList>0</priorityInBillList>
        <ingredients>
            <li>
                <thing>EM_Clay</thing>
                <countNeeded>100</countNeeded>
            </li>
        </ingredients>
        <ticks>120000</ticks>
        <results>
            <li>
                <thing>EM_ClayBricks</thing>
                <count>50</count>
            </li>
        </results>
        <isRainDependingProcess>true</isRainDependingProcess>
        <messageIfRainingWarning>EM_RainIsRuiningBricks</messageIfRainingWarning>
        <messageIfRaining>EM_RainRuinedBricks</messageIfRaining>
        <researchPrerequisites>
            <li>EM_BasicMasonry</li>
        </researchPrerequisites>
    </PipeSystem.ProcessDef>

</Defs>