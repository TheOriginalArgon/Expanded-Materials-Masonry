<Defs>

    <!-- ================ Shale ================ -->

    <ThingDef ParentName="UglyRockBase" Name="EM_ShaleBase">
        <defName>EM_Shale</defName>
        <label>shale</label>
        <description>A fine-grained sedimentary rock formed from the compaction of clay and minerals.</description>
        <graphicData>
            <color>(125,145,165)</color>
        </graphicData>
        <statBases>
            <MaxHitPoints>600</MaxHitPoints>
        </statBases>
        <building>
            <mineableThing>EM_ChunkShale</mineableThing>
            <mineableDropChance>0.25</mineableDropChance>
            <smoothedThing>EM_SmoothedShale</smoothedThing>
        </building>
    </ThingDef>

    <ThingDef ParentName="EM_ShaleBase">
        <defName>EM_SmoothedShale</defName>
        <label>smoothed shale</label>
        <description>A sedimentary rock formed from compacted fragments of minerals like quartz and calcite. It glows a smooth, faint blue and has a distinct layered texture.</description>
        <uiIconPath>Things/Building/Linked/WallSmooth_MenuIcon</uiIconPath>
        <graphicData>
            <texPath>Things/Building/Linked/RockSmooth_Atlas</texPath>
        </graphicData>
        <statBases>
            <Beauty>1</Beauty>
            <MarketValue>7</MarketValue>
        </statBases>
        <building>
            <isNaturalRock>false</isNaturalRock>
            <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
            <artificialForMeditationPurposes>false</artificialForMeditationPurposes>
            <smoothedThing />
            <paintable>true</paintable>
        </building>
        <saveCompressible>false</saveCompressible>
        <repairEffect>Repair</repairEffect>
    </ThingDef>

    <ThingDef ParentName="ChunkRockBase">
        <defName>EM_ChunkShale</defName>
        <label>shale chunk</label>
        <graphicData>
            <color>(125,145,165)</color>
        </graphicData>
        <statBases>
            <Mass>22</Mass>
        </statBases>
        <soundDrop>ChunkRock_Drop</soundDrop>
        <butcherProducts>
            <EM_BlocksShale>20</EM_BlocksShale>
        </butcherProducts>
    </ThingDef>

    <ThingDef ParentName="StoneBlocksBase">
        <defName>EM_BlocksShale</defName>
        <label>shale blocks</label>
        <description>Blocks of solid shale.</description>
        <graphicData>
            <color>(125,145,165)</color>
        </graphicData>
        <statBases>
            <Mass>1.1</Mass>
        </statBases>
        <stuffProps>
            <color>(125,145,165)</color>
            <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
            <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
            <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
            <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
            <stuffAdjective>shale</stuffAdjective>
            <statFactors>
                <Beauty>1.15</Beauty>
                <MaxHitPoints>1.45</MaxHitPoints>
                <WorkToMake>1.15</WorkToMake>
            </statFactors>
            <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
        </stuffProps>
    </ThingDef>

    <RecipeDef ParentName="MakeStoneBlocksBase">
        <defName>EM_Make_StoneBlocksShale</defName>
        <label>make shale blocks</label>
        <description>Cuts shale chunks into usable blocks.</description>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>EM_ChunkShale</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>EM_ChunkShale</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <EM_BlocksShale>20</EM_BlocksShale>
        </products>
    </RecipeDef>

