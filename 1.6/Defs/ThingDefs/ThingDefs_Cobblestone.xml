    <RecipeDef ParentName="EM_MakeCobblestoneBase">
        <defName>EM_Make_CobblestoneSandstone</defName>
        <label>make sandstone cobblestone</label>
        <description>Smashes sandstone chunks into usable cobblestone.</description>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>ChunkSandstone</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>ChunkSandstone</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <EM_CobblestoneSandstone>30</EM_CobblestoneSandstone>
