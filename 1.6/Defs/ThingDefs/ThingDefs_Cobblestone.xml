<Defs>

    <ThingDef ParentName="ResourceBase" Name="EM_CobblestoneBase" Abstract="True">
        <description>Roughly hewn stone. Mostly useful for building long-lasting, simple structures.</description>
        <graphicData>
            <texPath>Things/Item/Resource/EM_Cobblestone</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <soundInteract>Stone_Drop</soundInteract>
        <soundDrop>Stone_Drop</soundDrop>
        <useHitPoints>false</useHitPoints>
        <tradeability>Buyable</tradeability>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <MarketValue>0.7</MarketValue>
            <Beauty>-15</Beauty>
            <ConstructionSpeedFactor>0.6</ConstructionSpeedFactor>
        </statBases>
        <thingCategories>
            <li>EM_Cobblestone</li>
        </thingCategories>
        <burnableByRecipe>false</burnableByRecipe>
        <minRewardCount>10</minRewardCount>
        <stuffProps>
            <categories>
                <li>EM_Cobblestony</li>
            </categories>
            <commonality>0.20</commonality> <!-- because there are so many stone types -->
            <appearance>EM_Cobblestone</appearance>
            <statOffsets>
                <WorkToBuild>160</WorkToBuild>
            </statOffsets>
            <statFactors>
                <MaxHitPoints>1.7</MaxHitPoints>
                <Flammability>0</Flammability>
                <WorkToBuild>6.5</WorkToBuild>
            </statFactors>
            <canSuggestUseDefaultStuff>true</canSuggestUseDefaultStuff>
        </stuffProps>
        <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
        <allowedArchonexusCount>100</allowedArchonexusCount>
    </ThingDef>

